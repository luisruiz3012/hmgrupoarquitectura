---
import Layout from "../layouts/Layout.astro";
---

<Layout title="HM Pro Arquitectura | Estudio">
    <main class="pt-32 pb-24">
        <!-- Hero Section -->
        <section class="px-6 md:px-12 mb-32">
            <div class="max-w-7xl mx-auto">
                <p
                    class="label-text text-xs uppercase tracking-[0.2em] mb-8 text-tertiary"
                >
                    Sobre el Estudio
                </p>
                <h1
                    class="text-6xl md:text-8xl font-headline italic tracking-tighter leading-tight max-w-4xl mb-16"
                >
                    La <span class="text-primary">Arquitectura</span> como un acto
                    de permanencia.
                </h1>
                <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-end">
                    <div class="md:col-span-7">
                        <img
                            alt="Edificio moderno"
                            class="w-full h-[600px] object-cover grayscale brightness-90"
                            data-alt="monolithic concrete architectural structure with sharp clean lines and dramatic shadows against a clear sky"
                            src="https://lh3.googleusercontent.com/aida-public/AB6AXuB03teIJmQSwWo0r6B-dH1VENi1rdgsa88lWMpBarE10PhJtJxeLtXrjRK4z5kMOiFA_gYkcWZNmyHcIDec-wQCLD3pWLyKiMuXuAle1NCHbA2Cg-3oXTkZwf1teetX6rJLxBtPo8iq9gUdWuk2bN2CgD6Bee3kUgqfK0FMipWlnWpCyt-Lq6ek53fQb0aFM4boCcsWxmdOGdIdg62pmk7EiMtEmbRrFL9pNqtewu9Bn1631XMB8N-XZ7Cs6RhYVMHLStGvkTrxZHbr"
                        />
                    </div>
                    <div class="md:col-span-5 md:pb-12">
                        <p
                            class="font-body text-lg leading-relaxed text-secondary mb-8"
                        >
                            Fundado en 2010, HM Pro Arquitectura es una oficina
                            de arquitectura integral basada en la precisión y la
                            honestidad material. Nuestra organización se
                            especializa en brindar soluciones completas a través
                            de tres ramas principales:
                        </p>
                        <div class="flex flex-col gap-8 mt-8">
                            <div>
                                <h3
                                    class="font-headline text-xl mb-2 text-primary"
                                >
                                    Arquitectura y Diseño
                                </h3>
                                <p class="font-body text-secondary text-sm">
                                    Creación de conceptos visuales y
                                    planificación estructural desde el primer
                                    boceto hasta el desarrollo final.
                                </p>
                            </div>
                            <div>
                                <h3
                                    class="font-headline text-xl mb-2 text-primary"
                                >
                                    Construcción
                                </h3>
                                <p class="font-body text-secondary text-sm">
                                    Ejecución técnica rigurosa de proyectos
                                    arquitectónicos, asegurando la permanencia y
                                    calidad de los materiales.
                                </p>
                            </div>
                            <div>
                                <h3
                                    class="font-headline text-xl mb-4 text-primary"
                                >
                                    Consultoría Especializada
                                </h3>
                                <div class="space-y-4">
                                    <div>
                                        <h4
                                            class="font-body font-bold text-primary text-sm"
                                        >
                                            Evaluación Ambiental
                                        </h4>
                                        <p
                                            class="font-body text-secondary text-sm"
                                        >
                                            Realizamos análisis y dictámenes de
                                            impacto ambiental.
                                        </p>
                                    </div>
                                    <div>
                                        <h4
                                            class="font-body font-bold text-primary text-sm"
                                        >
                                            Topografía
                                        </h4>
                                        <p
                                            class="font-body text-secondary text-sm"
                                        >
                                            Cuentan con servicios de medición y
                                            análisis de terrenos.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- History & Detail Section -->
        <section class="bg-surface-container-low py-32 px-6 md:px-12">
            <div
                class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-12 gap-24"
            >
                <div class="md:col-span-4">
                    <div class="sticky top-40">
                        <h2 class="text-4xl font-headline mb-6">
                            Precisión del Detalle
                        </h2>
                        <div class="w-12 h-px bg-tertiary mb-6"></div>
                        <p
                            class="label-text text-xs uppercase tracking-widest text-secondary mb-12"
                        >
                            NUESTRO MANIFIESTO
                        </p>
                        <div class="space-y-8">
                            <div>
                                <span
                                    class="label-text text-[10px] uppercase tracking-tighter text-tertiary"
                                    >01</span
                                >
                                <h3 class="font-headline text-xl mt-2">
                                    Materia Prima
                                </h3>
                                <p class="text-sm text-secondary mt-2">
                                    Uso de materiales en su estado más puro:
                                    concreto expuesto, acero crudo y madera
                                    noble.
                                </p>
                            </div>
                            <div>
                                <span
                                    class="label-text text-[10px] uppercase tracking-tighter text-tertiary"
                                    >02</span
                                >
                                <h3 class="font-headline text-xl mt-2">
                                    Luz Escultural
                                </h3>
                                <p class="text-sm text-secondary mt-2">
                                    La luz natural como herramienta para definir
                                    volúmenes y transiciones temporales.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="md:col-span-8">
                    <div
                        class="aspect-[16/9] mb-12 bg-surface-container-highest"
                    >
                        <img
                            alt="Detalle arquitectónico"
                            class="w-full h-full object-cover grayscale"
                            data-alt="ultra close up of a sharp concrete corner intersection with a thin metal shadow reveal, architectural minimalism"
                            src="/img5.jpeg"
                        />
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                        <p class="font-body text-secondary leading-relaxed">
                            Creemos que la arquitectura de calidad no grita para
                            llamar la atención. Se revela lentamente a través
                            del tacto y la percepción del espacio. En HM Pro
                            Arquitectura, cada proyecto es un estudio sobre cómo
                            la estructura puede desaparecer para dejar que el
                            silencio hable.
                        </p>
                        <p class="font-body text-secondary leading-relaxed">
                            Desde el primer boceto técnico hasta la supervisión
                            de obra, mantenemos un estándar de rigor técnico que
                            asegura que la visión original se traduzca
                            perfectamente en la realidad construida.
                        </p>
                    </div>
                </div>
            </div>
        </section>
        <!-- Team Section -->
        <section class="py-32 px-6 md:px-12">
            <div class="max-w-7xl mx-auto">
                <div class="flex justify-between items-end mb-24">
                    <div>
                        <p
                            class="label-text text-xs uppercase tracking-[0.2em] mb-4 text-tertiary"
                        >
                            El Equipo
                        </p>
                        <h2 class="text-5xl font-headline">
                            Mentes detrás del Monolito
                        </h2>
                    </div>
                </div>
                <div
                    class="grid grid-cols-1 md:grid-cols-3 gap-1px bg-outline-variant/20"
                >
                    <!-- Member 1 -->
                    <div class="bg-surface p-0 group">
                        <div
                            class="aspect-[3/4] overflow-hidden bg-surface-container mb-6"
                        >
                            <img
                                alt="Architect portrait"
                                class="w-full h-full object-cover grayscale transition-transform duration-700 group-hover:scale-105"
                                data-alt="minimalist black and white studio portrait of a man with glasses, looking serious, high contrast lighting"
                                src="/Arqui1.jpeg"
                            />
                        </div>
                        <div class="px-2">
                            <h3 class="font-headline text-2xl mb-1">
                                Hector Manolo
                            </h3>
                            <p
                                class="label-text text-[10px] uppercase tracking-widest text-tertiary"
                            >
                                Arquitecto Senior
                            </p>
                        </div>
                    </div>
                    <!-- Member 2 -->
                    <div class="bg-surface p-0 group">
                        <div
                            class="aspect-[3/4] overflow-hidden bg-surface-container mb-6"
                        >
                            <img
                                alt="Architect portrait"
                                class="w-full h-full object-cover grayscale transition-transform duration-700 group-hover:scale-105"
                                data-alt="minimalist black and white studio portrait of a woman with short hair, high fashion architectural aesthetic"
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuDQNM-sdDR-5fbOn36BvSPpQYI3j9hP2bCnSLQFcQK-IYX3oD9e6gH7ebYfH910J5cWxFvM1EzPn8IgsktoZkZRgP4XeKRCQHyRxaWGi27LFkBvXZ4VyhGGMXLjVC8kmxVsgYZYJ7LviiqrtOZpT0ATrCqHKULOIYbM38Nck74ttKhLp_iaPrp79UiWGPqL8rH8BFNd5CVjsoCaNoYdfivKsf--XzEp6dnsBXmh8-bUX6iw1qcXddMEaD010s9GNgoimLJt7SMBsTsz"
                            />
                        </div>
                        <div class="px-2">
                            <h3 class="font-headline text-2xl mb-1">
                                Elena Ruiz
                            </h3>
                            <p
                                class="label-text text-[10px] uppercase tracking-widest text-tertiary"
                            >
                                Líder de Diseño Técnico
                            </p>
                        </div>
                    </div>
                    <!-- Member 3 -->
                    <div class="bg-surface p-0 group">
                        <div
                            class="aspect-[3/4] overflow-hidden bg-surface-container mb-6"
                        >
                            <img
                                alt="Architect portrait"
                                class="w-full h-full object-cover grayscale transition-transform duration-700 group-hover:scale-105"
                                data-alt="minimalist black and white studio portrait of a professional man, soft shadow, clean composition"
                                src="https://lh3.googleusercontent.com/aida-public/AB6AXuCD0NtqDtJ8yCF1L_JvPKVLM9OSWoy3R5qpo3uNjcbOHXNVEvkpUDJGT7YVLpv7zY5xoCABemjqxWlypmeFmE9GG7l-UpG4Yi9HfNLrFXbScPmjjI-dXMlnsNMnIiNxhuGCAYNySww0DiHSDG-5IjxuBtDbCbu2NWNiMVaHEYQcoIxTK7PDcFYtW8YmSNYqcoTwlUQiNigtltk_-muwn8pvB6hlzKI24-JYqQj7l-f8TrNWkxMoL-c5__g_UV-ohJUOc95UDh64THYU"
                            />
                        </div>
                        <div class="px-2">
                            <h3 class="font-headline text-2xl mb-1">
                                Marcus V. Thorne
                            </h3>
                            <p
                                class="label-text text-[10px] uppercase tracking-widest text-tertiary"
                            >
                                Arquitecto de Estructuras
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- Awards Section -->
        <section class="bg-black text-white py-32 px-6 md:px-12">
            <div class="max-w-7xl mx-auto">
                <div
                    class="grid grid-cols-1 md:grid-cols-12 gap-12 items-start"
                >
                    <div class="md:col-span-4">
                        <h2 class="text-4xl font-headline mb-8 italic">
                            Premios &amp; Reconocimientos
                        </h2>
                        <p class="font-body text-gray-400 text-sm max-w-xs">
                            Nuestra búsqueda incansable de la perfección ha sido
                            validada por la industria global a lo largo de una
                            década.
                        </p>
                    </div>
                    <div
                        class="md:col-span-8 border-l border-gray-800 md:pl-16"
                    >
                        <div class="space-y-12">
                            <div
                                class="group flex justify-between items-center py-4 border-b border-gray-900 transition-all hover:pl-4"
                            >
                                <div>
                                    <p
                                        class="label-text text-[10px] tracking-widest text-tertiary mb-2"
                                    >
                                        2023
                                    </p>
                                    <h4 class="text-2xl font-headline">
                                        Pritzker Architecture Prize - Nominee
                                    </h4>
                                </div>
                                <span
                                    class="material-symbols-outlined text-gray-700 group-hover:text-white transition-colors"
                                    data-icon="star">star</span
                                >
                            </div>
                            <div
                                class="group flex justify-between items-center py-4 border-b border-gray-900 transition-all hover:pl-4"
                            >
                                <div>
                                    <p
                                        class="label-text text-[10px] tracking-widest text-tertiary mb-2"
                                    >
                                        2021
                                    </p>
                                    <h4 class="text-2xl font-headline">
                                        Mies van der Rohe Award - Finalist
                                    </h4>
                                </div>
                                <span
                                    class="material-symbols-outlined text-gray-700 group-hover:text-white transition-colors"
                                    data-icon="architecture">architecture</span
                                >
                            </div>
                            <div
                                class="group flex justify-between items-center py-4 border-b border-gray-900 transition-all hover:pl-4"
                            >
                                <div>
                                    <p
                                        class="label-text text-[10px] tracking-widest text-tertiary mb-2"
                                    >
                                        2019
                                    </p>
                                    <h4 class="text-2xl font-headline">
                                        Global Design Excellence Gold
                                    </h4>
                                </div>
                                <span
                                    class="material-symbols-outlined text-gray-700 group-hover:text-white transition-colors"
                                    data-icon="workspace_premium"
                                    >workspace_premium</span
                                >
                            </div>
                            <div
                                class="group flex justify-between items-center py-4 border-b border-gray-900 transition-all hover:pl-4"
                            >
                                <div>
                                    <p
                                        class="label-text text-[10px] tracking-widest text-tertiary mb-2"
                                    >
                                        2017
                                    </p>
                                    <h4 class="text-2xl font-headline">
                                        Innovación Material - ArchDaily
                                    </h4>
                                </div>
                                <span
                                    class="material-symbols-outlined text-gray-700 group-hover:text-white transition-colors"
                                    data-icon="category">category</span
                                >
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        <!-- CTA Section -->
        <section class="py-48 px-6 text-center">
            <h2 class="text-4xl md:text-6xl font-headline mb-12">
                ¿Construimos el futuro?
            </h2>
            <a
                class="inline-block bg-primary text-on-primary px-12 py-5 font-label uppercase text-sm tracking-widest hover:bg-tertiary transition-all duration-300"
                href="#"
            >
                Contactar Estudio
            </a>
        </section>
    </main>
</Layout>
