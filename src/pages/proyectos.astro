---
import Layout from "../layouts/Layout.astro";
---

<Layout title="HM Pro Arquitectura | Proyectos">
        <main class="pt-32 px-6 md:px-12 pb-24">
            <header class="mb-24 max-w-4xl">
                <h1
                    class="font-headline italic text-5xl md:text-7xl mb-8 tracking-tighter"
                >
                    Proyectos Seleccionados
                </h1>
                <p
                    class="font-body text-secondary text-lg max-w-2xl leading-relaxed"
                >
                    Una curaduría de intervenciones arquitectónicas que exploran
                    la permanencia, el material y la luz. Proyectos
                    residenciales y comerciales diseñados bajo el rigor de la
                    precisión técnica y la visión artística.
                </p>
            </header>
            <section class="mb-20">
                <div
                    class="flex flex-wrap gap-8 items-end border-b border-outline-variant/20 pb-6"
                >
                    <span
                        class="font-label text-[10px] uppercase tracking-[0.2em] text-outline mb-1"
                        >Filtrar por:</span
                    >
                    <button
                        class="font-label uppercase text-xs tracking-widest text-primary border-b-2 border-tertiary pb-1"
                        >Todos</button
                    >
                    <button
                        class="font-label uppercase text-xs tracking-widest text-secondary hover:text-primary transition-colors pb-1"
                        >Residencial</button
                    >
                    <button
                        class="font-label uppercase text-xs tracking-widest text-secondary hover:text-primary transition-colors pb-1"
                        >Comercial</button
                    >
                    <button
                        class="font-label uppercase text-xs tracking-widest text-secondary hover:text-primary transition-colors pb-1"
                        >Urbanismo</button
                    >
                </div>
            </section>
            <section
                class="grid grid-cols-1 md:grid-cols-12 gap-y-32 md:gap-x-12"
            >
                <div class="md:col-span-8 group">
                    <div
                        class="relative overflow-hidden aspect-[16/9] mb-6 bg-surface-container-low"
                    >
                        <img
                            alt="Minimalist concrete villa"
                            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 ease-in-out"
                            data-alt="Brutalist concrete luxury villa with floor-to-ceiling glass windows at sunset, reflecting a calm pool, minimalist landscape design"
                            src="/img1.jpeg"
                        />
                        <div
                            class="absolute bottom-6 right-6 flex items-center gap-2"
                        >
                            <div class="h-[1px] w-12 bg-white/50"></div>
                            <span
                                class="font-label text-white text-[10px] tracking-widest"
                                >01</span
                            >
                        </div>
                    </div>
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="font-headline text-3xl mb-2 italic">
                                Casa Península
                            </h3>
                            <p
                                class="font-label uppercase text-[10px] tracking-widest text-outline"
                            >
                                Residencial — Punta del Este, 2023
                            </p>
                        </div>
                        <span
                            class="material-symbols-outlined text-tertiary"
                            data-icon="north_east">north_east</span
                        >
                    </div>
                </div>
                <div class="md:col-span-4 md:mt-48 group">
                    <div
                        class="relative overflow-hidden aspect-[3/4] mb-6 bg-surface-container-low"
                    >
                        <img
                            alt="Modern office architecture"
                            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 ease-in-out"
                            data-alt="High-end corporate building lobby with dark stone textures, linear golden lighting fixtures and minimalist geometric reception desk"
                            src="/img2.jpeg"
                        />
                        <div
                            class="absolute bottom-6 right-6 flex items-center gap-2"
                        >
                            <div class="h-[1px] w-12 bg-white/50"></div>
                            <span
                                class="font-label text-white text-[10px] tracking-widest"
                                >02</span
                            >
                        </div>
                    </div>
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="font-headline text-2xl mb-2">
                                Edificio Prisma
                            </h3>
                            <p
                                class="font-label uppercase text-[10px] tracking-widest text-outline"
                            >
                                Comercial — Ciudad de México, 2022
                            </p>
                        </div>
                    </div>
                </div>
                <div class="md:col-span-4 group">
                    <div
                        class="relative overflow-hidden aspect-[3/4] mb-6 bg-surface-container-low"
                    >
                        <img
                            alt="Urban public space"
                            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 ease-in-out"
                            data-alt="Minimalist urban plaza with geometric stone benches, precise landscaping and dramatic shadows cast by tall buildings"
                            src="/img3.jpeg"
                        />
                        <div
                            class="absolute bottom-6 right-6 flex items-center gap-2"
                        >
                            <div class="h-[1px] w-12 bg-white/50"></div>
                            <span
                                class="font-label text-white text-[10px] tracking-widest"
                                >03</span
                            >
                        </div>
                    </div>
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="font-headline text-2xl mb-2">
                                Plaza Monolito
                            </h3>
                            <p
                                class="font-label uppercase text-[10px] tracking-widest text-outline"
                            >
                                Urbanismo — Madrid, 2024
                            </p>
                        </div>
                    </div>
                </div>
                <div class="md:col-span-8 group">
                    <div
                        class="relative overflow-hidden aspect-[16/9] mb-6 bg-surface-container-low"
                    >
                        <img
                            alt="Luxury mountain retreat"
                            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 ease-in-out"
                            data-alt="Secluded luxury retreat made of dark charred wood and glass, nestled in a pine forest with moody morning mist"
                            src="/img4.jpeg"
                        />
                        <div
                            class="absolute bottom-6 right-6 flex items-center gap-2"
                        >
                            <div class="h-[1px] w-12 bg-white/50"></div>
                            <span
                                class="font-label text-white text-[10px] tracking-widest"
                                >04</span
                            >
                        </div>
                    </div>
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="font-headline text-3xl mb-2 italic">
                                Refugio Elemental
                            </h3>
                            <p
                                class="font-label uppercase text-[10px] tracking-widest text-outline"
                            >
                                Residencial — Los Andes, 2021
                            </p>
                        </div>
                        <span
                            class="material-symbols-outlined text-tertiary"
                            data-icon="north_east">north_east</span
                        >
                    </div>
                </div>
                <div class="md:col-span-12 group mt-12">
                    <div
                        class="relative overflow-hidden h-[600px] mb-8 bg-surface-container-low"
                    >
                        <img
                            alt="Minimalist art gallery"
                            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 ease-in-out"
                            data-alt="Vast minimalist art gallery with polished concrete floors and large white walls, dramatic overhead skylight illuminating a single sculpture"
                            src="/img5.jpeg"
                        />
                        <div class="absolute top-12 left-12 max-w-sm">
                            <h2
                                class="font-headline text-white text-5xl italic leading-none mb-4"
                            >
                                La Galería Blanca
                            </h2>
                            <p
                                class="font-label text-white/70 uppercase text-[10px] tracking-[0.3em]"
                            >
                                Comercial • Proyecto del Año 2023
                            </p>
                        </div>
                    </div>
                </div>
            </section>
            <section
                class="mt-48 flex flex-col md:flex-row items-center justify-between gap-12 bg-surface-container-low p-12 md:p-24"
            >
                <div class="max-w-xl">
                    <h2 class="font-headline text-4xl mb-6 tracking-tighter">
                        ¿Tienes una visión en mente?
                    </h2>
                    <p class="font-body text-secondary mb-10">
                        Estamos listos para transformar conceptos en estructuras
                        permanentes. Colaboremos en tu próximo proyecto
                        arquitectónico.
                    </p>
                    <button
                        class="bg-primary text-on-primary px-10 py-5 font-label uppercase text-xs tracking-widest hover:bg-tertiary transition-all duration-300"
                    >
                        Iniciar Consulta
                    </button>
                </div>
                <div class="w-full md:w-1/3">
                    <div class="h-[1px] w-full bg-outline-variant mb-6"></div>
                    <div
                        class="flex justify-between font-label text-[10px] uppercase tracking-widest mb-4"
                    >
                        <span>Proyectos Activos</span>
                        <span>12</span>
                    </div>
                    <div
                        class="flex justify-between font-label text-[10px] uppercase tracking-widest mb-4"
                    >
                        <span>Premios Internacionales</span>
                        <span>08</span>
                    </div>
                    <div
                        class="flex justify-between font-label text-[10px] uppercase tracking-widest"
                    >
                        <span>Años de Experiencia</span>
                        <span>15</span>
                    </div>
                </div>
            </section>
        </main>
</Layout>
