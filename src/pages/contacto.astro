---
import Layout from "../layouts/Layout.astro";
---

<Layout title="HM Pro Arquitectura | Contacto">
        <main class="pt-32 pb-24 px-6 md:px-12 max-w-screen-2xl mx-auto">
            <!-- Header Section -->
            <section class="mb-24">
                <h1
                    class="font-headline italic text-5xl md:text-8xl text-primary leading-tight mb-6"
                >
                    Hablemos de <br />su próximo espacio.
                </h1>
                <p
                    class="font-label uppercase tracking-[0.2em] text-xs text-secondary max-w-md"
                >
                    HM PRO ARQUITECTURA — PRECISIÓN, PERMANENCIA Y VISIÓN
                    ARQUITECTÓNICA.
                </p>
            </section>
            <!-- Main Grid Layout -->
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 lg:gap-24">
                <!-- Contact Form (The Monolith Approach) -->
                <div class="lg:col-span-7 space-y-16">
                    <form class="space-y-12">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                            <div class="relative group">
                                <label
                                    class="font-label text-[10px] uppercase tracking-widest text-secondary block mb-2"
                                    >Nombre Completo</label
                                >
                                <input
                                    class="w-full bg-transparent border-b border-outline-variant focus:border-tertiary focus:ring-0 transition-colors py-3 outline-none font-body placeholder-gray-300"
                                    placeholder="Escriba su nombre..."
                                    type="text"
                                />
                            </div>
                            <div class="relative group">
                                <label
                                    class="font-label text-[10px] uppercase tracking-widest text-secondary block mb-2"
                                    >Correo Electrónico</label
                                >
                                <input
                                    class="w-full bg-transparent border-b border-outline-variant focus:border-tertiary focus:ring-0 transition-colors py-3 outline-none font-body placeholder-gray-300"
                                    placeholder="nombre@ejemplo.com"
                                    type="email"
                                />
                            </div>
                        </div>
                        <div class="relative group">
                            <label
                                class="font-label text-[10px] uppercase tracking-widest text-secondary block mb-2"
                                >Interés del Proyecto</label
                            >
                            <select
                                class="w-full bg-transparent border-b border-outline-variant focus:border-tertiary focus:ring-0 transition-colors py-3 outline-none font-body appearance-none"
                            >
                                <option>Residencial de Lujo</option>
                                <option>Desarrollo Comercial</option>
                                <option>Diseño de Interiores</option>
                                <option>Restauración Histórica</option>
                            </select>
                        </div>
                        <div class="relative group">
                            <label
                                class="font-label text-[10px] uppercase tracking-widest text-secondary block mb-2"
                                >Mensaje / Brief</label
                            >
                            <textarea
                                class="w-full bg-transparent border-b border-outline-variant focus:border-tertiary focus:ring-0 transition-colors py-4 outline-none font-body placeholder-gray-300 resize-none"
                                placeholder="Describa su visión..."
                                rows="4"></textarea>
                        </div>
                        <button
                            class="bg-primary text-on-primary px-12 py-5 font-label uppercase tracking-widest text-xs hover:bg-tertiary transition-all duration-300 flex items-center group"
                            type="submit"
                        >
                            Enviar Consulta
                            <span
                                class="material-symbols-outlined ml-4 text-sm group-hover:translate-x-2 transition-transform"
                                data-icon="arrow_forward">arrow_forward</span
                            >
                        </button>
                    </form>
                    <!-- Stylized Grayscale Map -->
                    <div
                        class="w-full h-96 bg-surface-container-highest relative overflow-hidden grayscale contrast-125 brightness-75"
                    >
                        <img
                            class="w-full h-full object-cover mix-blend-multiply opacity-50"
                            data-alt="abstract architectural map texture in grayscale with high contrast lines and geometric urban grid layout"
                            data-location="Madrid"
                            src="/img1.jpeg"
                        />
                        <div
                            class="absolute inset-0 border border-white/10 pointer-events-none"
                        >
                        </div>
                        <div
                            class="absolute top-1/2 left-1/3 w-2 h-2 bg-tertiary rounded-full"
                        >
                        </div>
                        <div
                            class="absolute bottom-1/4 right-1/2 w-2 h-2 bg-tertiary rounded-full"
                        >
                        </div>
                    </div>
                </div>
                <!-- Offices & Info -->
                <div class="lg:col-span-5 space-y-24">
                    <!-- Madrid Office -->
                    <div class="space-y-6">
                        <div class="flex items-center space-x-4">
                            <span
                                class="font-label text-[10px] uppercase tracking-widest text-tertiary px-3 py-1 bg-tertiary/10"
                                >European HQ</span
                            >
                        </div>
                        <h2 class="font-headline text-4xl italic">Madrid</h2>
                        <div
                            class="space-y-2 text-secondary font-body leading-relaxed"
                        >
                            <p>Calle de Velázquez, 14</p>
                            <p>28001 Madrid, España</p>
                            <p
                                class="pt-4 text-primary font-mono text-xs tracking-tighter"
                            >
                                +34 912 345 678
                            </p>
                            <p
                                class="text-primary font-mono text-xs tracking-tighter"
                            >
                                contact@hmproarq.com
                            </p>
                        </div>
                    </div>
                    <!-- Santiago Office -->
                    <div class="space-y-6">
                        <div class="flex items-center space-x-4">
                            <span
                                class="font-label text-[10px] uppercase tracking-widest text-tertiary px-3 py-1 bg-tertiary/10"
                                >Latam Studio</span
                            >
                        </div>
                        <h2 class="font-headline text-4xl italic">Santiago</h2>
                        <div
                            class="space-y-2 text-secondary font-body leading-relaxed"
                        >
                            <p>Av. Nueva Costanera 3300</p>
                            <p>Vitacura, Santiago, Chile</p>
                            <p
                                class="pt-4 text-primary font-mono text-xs tracking-tighter"
                            >
                                +56 2 2345 6789
                            </p>
                            <p
                                class="text-primary font-mono text-xs tracking-tighter"
                            >
                                contact@hmproarq.com
                            </p>
                        </div>
                    </div>
                    <!-- Social & Professional -->
                    <div
                        class="pt-12 space-y-8 border-t border-outline-variant/30"
                    >
                        <h3
                            class="font-label text-[10px] uppercase tracking-widest text-secondary"
                        >
                            Redes Profesionales
                        </h3>
                        <div class="flex flex-col space-y-4">
                            <a
                                class="group flex items-center justify-between text-primary font-label text-sm uppercase tracking-wide py-2 border-b border-transparent hover:border-tertiary transition-all"
                                href="#"
                            >
                                Instagram / @hmpro_arq
                                <span
                                    class="material-symbols-outlined text-xs group-hover:text-tertiary"
                                    data-icon="north_east">north_east</span
                                >
                            </a>
                            <a
                                class="group flex items-center justify-between text-primary font-label text-sm uppercase tracking-wide py-2 border-b border-transparent hover:border-tertiary transition-all"
                                href="#"
                            >
                                LinkedIn / HM Pro Arquitectura
                                <span
                                    class="material-symbols-outlined text-xs group-hover:text-tertiary"
                                    data-icon="north_east">north_east</span
                                >
                            </a>
                            <a
                                class="group flex items-center justify-between text-primary font-label text-sm uppercase tracking-wide py-2 border-b border-transparent hover:border-tertiary transition-all"
                                href="#"
                            >
                                ArchDaily / Portfolio
                                <span
                                    class="material-symbols-outlined text-xs group-hover:text-tertiary"
                                    data-icon="north_east">north_east</span
                                >
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </main>
</Layout>
