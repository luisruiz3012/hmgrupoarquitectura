---
import Layout from "../layouts/Layout.astro";
---

<Layout title="HM Pro Arquitectura | Fase de Ejecución">
        <main class="pt-32 px-6 md:px-12 pb-24">
            <header class="mb-24 max-w-4xl">
                <h1
                    class="font-headline italic text-5xl md:text-7xl mb-8 tracking-tighter"
                >
                    Fase de Ejecución
                </h1>
                <p
                    class="font-body text-secondary text-lg max-w-2xl leading-relaxed"
                >
                    Nuestra fase de ejecución garantiza que la precisión técnica y el rigor arquitectónico se mantengan desde los cimientos hasta los detalles finales. Transformamos la visión en materia con los más altos estándares constructivos.
                </p>
            </header>

            <section
                class="grid grid-cols-1 md:grid-cols-12 gap-8"
            >
				<div class="md:col-span-8 overflow-hidden aspect-[16/9]">
					<img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105" src="/Fase de Ejecucion/ejecucion1.jpeg" />
				</div>
				<div class="md:col-span-4 overflow-hidden aspect-[3/4]">
					<img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105" src="/Fase de Ejecucion/ejecucion2.jpeg" />
				</div>
				<div class="md:col-span-4 overflow-hidden aspect-[3/4]">
					<img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105" src="/Fase de Ejecucion/ejecucion3.jpeg" />
				</div>
				<div class="md:col-span-8 overflow-hidden aspect-[16/9]">
					<img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105" src="/Fase de Ejecucion/ejecucion4.jpeg" />
				</div>
				<div class="md:col-span-6 overflow-hidden aspect-video">
					<img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105" src="/Fase de Ejecucion/ejecucion5.jpeg" />
				</div>
				<div class="md:col-span-6 overflow-hidden aspect-video">
					<img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105" src="/Fase de Ejecucion/ejecucion6.jpeg" />
				</div>
				<div class="md:col-span-4 overflow-hidden aspect-[4/3]">
					<img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105" src="/Fase de Ejecucion/ejecucion7.jpeg" />
				</div>
				<div class="md:col-span-8 overflow-hidden aspect-[16/9]">
					<img class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105" src="/Fase de Ejecucion/ejecucion8.jpeg" />
				</div>
			</section>
            <section
                class="mt-48 flex flex-col md:flex-row items-center justify-between gap-12 bg-surface-container-low p-12 md:p-24"
            >
                <div class="max-w-xl">
                    <h2 class="font-headline text-4xl mb-6 tracking-tighter">
                        ¿Tienes una visión en mente?
                    </h2>
                    <p class="font-body text-secondary mb-10">
                        Estamos listos para transformar conceptos en estructuras
                        permanentes. Colaboremos en tu próximo proyecto
                        arquitectónico.
                    </p>
                    <button
                        class="bg-primary text-on-primary px-10 py-5 font-label uppercase text-xs tracking-widest hover:bg-tertiary transition-all duration-300"
                    >
                        Iniciar Consulta
                    </button>
                </div>
                <div class="w-full md:w-1/3">
                    <div class="h-[1px] w-full bg-outline-variant mb-6"></div>
                    <div
                        class="flex justify-between font-label text-[10px] uppercase tracking-widest mb-4"
                    >
                        <span>Proyectos Activos</span>
                        <span>12</span>
                    </div>
                    <div
                        class="flex justify-between font-label text-[10px] uppercase tracking-widest mb-4"
                    >
                        <span>Premios Internacionales</span>
                        <span>08</span>
                    </div>
                    <div
                        class="flex justify-between font-label text-[10px] uppercase tracking-widest"
                    >
                        <span>Años de Experiencia</span>
                        <span>15</span>
                    </div>
                </div>
            </section>
        </main>
</Layout>
