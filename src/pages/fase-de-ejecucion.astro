    { src: "/Fase de Ejecucion/ejecucion9.jpeg", span: "md:col-span-8", aspect: "aspect-[16/9]" },
    { src: "/Fase de Ejecucion/ejecucion10.jpeg", span: "md:col-span-4", aspect: "aspect-[3/4]" },
    { src: "/Fase de Ejecucion/ejecucion11.jpeg", span: "md:col-span-4", aspect: "aspect-[3/4]" },
    { src: "/Fase de Ejecucion/ejecucion12.jpeg", span: "md:col-span-8", aspect: "aspect-[16/9]" },
    { src: "/Fase de Ejecucion/ejecucion13.jpeg", span: "md:col-span-6", aspect: "aspect-video" },
    { src: "/Fase de Ejecucion/ejecucion14.jpeg", span: "md:col-span-6", aspect: "aspect-video" },
    { src: "/Fase de Ejecucion/ejecucion15.jpeg", span: "md:col-span-4", aspect: "aspect-[4/3]" },
    { src: "/Fase de Ejecucion/ejecucion16.jpeg", span: "md:col-span-8", aspect: "aspect-[16/9]" },
    { src: "/Fase de Ejecucion/ejecucion17.jpeg", span: "md:col-span-8", aspect: "aspect-[16/9]" },
    { src: "/Fase de Ejecucion/ejecucion18.jpeg", span: "md:col-span-4", aspect: "aspect-[3/4]" },
    { src: "/Fase de Ejecucion/ejecucion19.jpeg", span: "md:col-span-4", aspect: "aspect-[3/4]" },
    { src: "/Fase de Ejecucion/ejecucion20.jpeg", span: "md:col-span-8", aspect: "aspect-[16/9]" },
    { src: "/Fase de Ejecucion/ejecucion21.jpeg", span: "md:col-span-6", aspect: "aspect-video" },
    { src: "/Fase de Ejecucion/ejecucion22.jpeg", span: "md:col-span-6", aspect: "aspect-video" },
    { src: "/Fase de Ejecucion/ejecucion23.jpeg", span: "md:col-span-12", aspect: "aspect-[21/9]" },
    { src: "/Fase de Ejecucion/ejecucion24.jpeg", span: "md:col-span-6", aspect: "aspect-video" },
    { src: "/Fase de Ejecucion/ejecucion25.jpeg", span: "md:col-span-6", aspect: "aspect-video" },
    { src: "/Fase de Ejecucion/ejecucion26.jpeg", span: "md:col-span-8", aspect: "aspect-[16/9]" },
    { src: "/Fase de Ejecucion/ejecucion27.jpeg", span: "md:col-span-4", aspect: "aspect-[3/4]" },
    { src: "/Fase de Ejecucion/ejecucion28.jpeg", span: "md:col-span-8", aspect: "aspect-[16/9]" },
];
---

<Layout title="HM Pro Arquitectura | Fase de Ejecución">
    <main class="pt-32 px-6 md:px-12 pb-24">
        <header class="mb-24 max-w-4xl">
            <h1 class="font-headline italic text-5xl md:text-7xl mb-8 tracking-tighter">
                Fase de Ejecución
            </h1>
            <p class="font-body text-secondary text-lg max-w-2xl leading-relaxed">
                Nuestra fase de ejecución garantiza que la precisión técnica y el rigor arquitectónico se mantengan desde los cimientos hasta los detalles finales. Transformamos la visión en materia con los más altos estándares constructivos.
            </p>
        </header>

        <section class="grid grid-cols-1 md:grid-cols-12 gap-8">
            {images.map((image) => (
                <div class={`${image.span} overflow-hidden ${image.aspect}`}>
                    <img 
                        class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105" 
                        src={image.src} 
                        alt="Fase de ejecución"
                        loading="lazy"
                    />
                </div>
            ))}
        </section>

        <section class="mt-48 flex flex-col md:flex-row items-center justify-between gap-12 bg-surface-container-low p-12 md:p-24">
            <div class="max-w-xl">
                <h2 class="font-headline text-4xl mb-6 tracking-tighter">
                    ¿Tienes una visión en mente?
                </h2>
                <p class="font-body text-secondary mb-10">
                    Estamos listos para transformar conceptos en estructuras permanentes. Colaboremos en tu próximo proyecto arquitectónico.
                </p>
                <button class="bg-primary text-on-primary px-10 py-5 font-label uppercase text-xs tracking-widest hover:bg-tertiary transition-all duration-300">
                    Iniciar Consulta
                </button>
            </div>
            <div class="w-full md:w-1/3">
                <div class="h-[1px] w-full bg-outline-variant mb-6"></div>
                <div class="flex justify-between font-label text-[10px] uppercase tracking-widest mb-4">
                    <span>Proyectos Activos</span>
                    <span>12</span>
                </div>
                <div class="flex justify-between font-label text-[10px] uppercase tracking-widest mb-4">
                    <span>Premios Internacionales</span>
                    <span>08</span>
                </div>
                <div class="flex justify-between font-label text-[10px] uppercase tracking-widest">
                    <span>Años de Experiencia</span>
                    <span>15</span>
                </div>
            </div>
        </section>
    </main>
</Layout>
