const images = [
    { src: "/Fase de Ejecucion/ejecucion1.jpeg", span: "md:col-span-8", aspect: "aspect-[16/9]" },
    { src: "/Fase de Ejecucion/ejecucion2.jpeg", span: "md:col-span-4", aspect: "aspect-[3/4]" },
    { src: "/Fase de Ejecucion/ejecucion3.jpeg", span: "md:col-span-4", aspect: "aspect-[3/4]" },
    { src: "/Fase de Ejecucion/ejecucion4.jpeg", span: "md:col-span-8", aspect: "aspect-[16/9]" },
    { src: "/Fase de Ejecucion/ejecucion5.jpeg", span: "md:col-span-6", aspect: "aspect-video" },
    { src: "/Fase de Ejecucion/ejecucion6.jpeg", span: "md:col-span-6", aspect: "aspect-video" },
    { src: "/Fase de Ejecucion/ejecucion7.jpeg", span: "md:col-span-4", aspect: "aspect-[4/3]" },
