---
import Layout from "../layouts/Layout.astro";
import Team from "../components/Team.astro";

const designImages = [
	{ src: "/Fase de Diseno/fase1.jpeg", span: "md:col-span-8" },
	{ src: "/Fase de Diseno/fase2.jpeg", span: "md:col-span-4" },
	{ src: "/Fase de Diseno/fase3.jpeg", span: "md:col-span-4" },
	{ src: "/Fase de Diseno/fase4.jpeg", span: "md:col-span-4" },
	{ src: "/Fase de Diseno/fase5.jpeg", span: "md:col-span-4" },
	{ src: "/Fase de Diseno/fase6.jpeg", span: "md:col-span-6" },
	{ src: "/Fase de Diseno/fase7.jpeg", span: "md:col-span-6" },
];
---

<Layout title="HM Pro Arquitectura | Inicio">
	<!-- Hero Section -->
	<header
		class="relative h-screen w-full flex items-center justify-center overflow-hidden"
	>
		<div class="absolute inset-0 z-0">
			<img
				class="w-full h-full object-cover scale-105"
				data-alt="Ultra-minimalist modern luxury residence with floor-to-ceiling glass walls, sleek concrete planes, and warm interior lighting during twilight hours."
				src="https://lh3.googleusercontent.com/aida-public/AB6AXuAYxT265URmhVEXl7tMXqko5VL787SYIdGR1T-zEyV1tlePtJo1p7Gs-_uVncZ1rU0cFZIMqRcBWjulb7GHtX9vzMFJsABEUamDOf55dTI-5a4brcK8pGlBEHKLCn7cJfldYmjLlytSDfOCBgX--YaTYdmgyhFmbXGAUS771dhmHUKYsCQob2Kx0CziXCFSWGKw_8w7RXK6xjiQNEwttMPvBV9kF8U3g2lGNTZEON-9F1Tl9MqPftpsXzsRAPOlNf4KpT8M2FxKllID"
			/>
			<div class="absolute inset-0 bg-black/30"></div>
		</div>
		<div class="relative z-10 text-center px-6 max-w-5xl text-white">
			<h1
				class="font-headline text-5xl md:text-7xl lg:text-8xl text-on-primary font-bold tracking-tight mb-8"
			>
				HM PRO ARQUITECTURA
			</h1>
			<div class="w-24 h-0.5 bg-tertiary mx-auto mb-8"></div>
			<p
				class="font-label text-on-primary uppercase tracking-[0.3em] text-sm md:text-lg"
			>
				Transformando visiones en estructuras habitables
			</p>
		</div>
		<div
			class="absolute bottom-12 left-1/2 -translate-x-1/2 text-on-primary flex flex-col items-center gap-2"
		>
			<span
				class="font-label text-white text-[10px] tracking-widest uppercase"
				>Desliza para Explorar</span
			>
			<div class="w-[1px] h-12 bg-on-primary/30"></div>
		</div>
	</header>
	<!-- Portfolio Section (Asymmetric Masonry) -->
	<section class="py-32 px-8 lg:px-24 bg-surface" id="projects">
		<div
			class="flex flex-col md:flex-row justify-between items-end mb-24 gap-8"
		>
			<div class="max-w-xl">
				<h2 class="font-headline text-4xl md:text-6xl mb-6">
					Obras Seleccionadas
				</h2>
				<p class="text-on-surface-variant font-body leading-relaxed">
					Explorando el equilibrio entre el entorno natural y la
					precisión geométrica.
				</p>
			</div>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-12 gap-12 lg:gap-24">
			<!-- Project 1 -->
			<div class="md:col-span-7 group relative overflow-hidden">
				<div class="aspect-[4/3] w-full overflow-hidden">
					<img
						class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-110"
						data-alt="Contemporary white minimalist villa with cantilevered roof over a still infinity pool, sharp lines, blue hour lighting."
						src="/obra1.jpeg"
					/>
				</div>
			</div>
			<!-- Project 2 -->
			<div
				class="md:col-span-5 group relative overflow-hidden pt-24 md:pt-48"
			>
				<div class="aspect-[3/4] w-full overflow-hidden">
					<img
						class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-110"
						data-alt="Sleek glass and black steel commercial office building at night showing illuminated interiors and geometric staircase."
						src="/obra2.jpeg"
					/>
				</div>
			</div>
			<!-- Project 3 -->
			<div class="md:col-span-4 group relative overflow-hidden">
				<div class="aspect-square w-full overflow-hidden">
					<img
						class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-110"
						data-alt="Interior of a minimalist concrete living room with large architectural window framing a forest view, soft natural light."
						src="/obra3.jpeg"
					/>
				</div>
			</div>
			<!-- Project 4 -->
			<div class="md:col-span-8 group relative overflow-hidden md:-mt-24">
				<div class="aspect-[16/9] w-full overflow-hidden">
					<img
						class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-110"
						data-alt="Large scale urban masterplan rendering with sustainable wood buildings and integrated green pedestrian pathways, bright daylight."
						src="/img5.jpeg"
					/>
				</div>
			</div>
		</div>
	</section>
	<!-- Scale Indicator Component -->
	<div class="w-full px-24 py-12 flex items-center gap-8 bg-surface">
		<span
			class="font-label text-[10px] uppercase tracking-widest text-outline"
			>Escala 1:500</span
		>
		<div class="flex-grow h-[1px] bg-outline-variant relative">
			<div class="absolute left-0 top-0 h-full w-1/3 bg-primary"></div>
		</div>
		<span
			class="font-label text-[10px] uppercase tracking-widest text-outline"
			>Evolución del Proyecto</span
		>
	</div>
	<!-- Design Philosophy Section -->
	<section
		class="py-48 px-8 lg:px-24 bg-surface-container-low flex flex-col items-center"
		id="philosophy"
	>
		<div class="max-w-4xl text-center space-y-12">
			<span
				class="font-label text-xs uppercase tracking-[0.5em] text-tertiary"
				>Filosofía</span
			>
			<h2 class="font-headline text-4xl md:text-6xl leading-tight">
				Sustentabilidad radical a través de la innovación técnica.
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-16 text-left mt-24">
				<div class="space-y-6">
					<p class="text-on-surface-variant leading-relaxed text-lg">
						No construimos simplemente muros; orquestamos
						experiencias donde la luz, el material y la función
						convergen. Nuestra metodología se basa en la eliminación
						de lo superfluo para revelar la esencia de la
						estructura.
					</p>
				</div>
				<div class="space-y-6">
					<p class="text-on-surface-variant leading-relaxed text-lg">
						Utilizamos tecnologías BIM de vanguardia para garantizar
						una precisión milimétrica, reduciendo el desperdicio de
						materiales y optimizando la eficiencia energética desde
						el primer boceto.
					</p>
				</div>
			</div>
		</div>
	</section>
	<!-- Fases de Diseño Section -->
	<section class="py-32 px-8 lg:px-24 bg-surface" id="fases">
		<div class="max-w-xl mb-24">
			<h2 class="font-headline text-4xl md:text-6xl mb-6">
				Fases de Diseño
			</h2>
			<p class="text-on-surface-variant font-body leading-relaxed">
				El proceso detallado que seguimos para conceptualizar y
				perfeccionar cada detalle antes de la ejecución.
			</p>
		</div>
		<div class="grid grid-cols-1 md:grid-cols-12 gap-8 lg:gap-12">
			{
				designImages.map((image) => (
					<div class={`${image.span} overflow-hidden`}>
						<img
							class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-700 hover:scale-105"
							src={image.src}
							alt="Fase de diseño"
							loading="lazy"
						/>
					</div>
				))
			}
		</div>
	</section>
	<!-- Technical Services Section -->
	<section class="py-32 px-8 lg:px-24 bg-surface">
		<div
			class="grid grid-cols-1 md:grid-cols-4 gap-px bg-outline-variant/30"
		>
			<!-- Service 1 -->
			<div
				class="bg-surface p-12 space-y-8 group hover:bg-surface-container-highest transition-colors duration-500"
			>
				<span
					class="material-symbols-outlined text-4xl text-primary"
					data-icon="architecture">architecture</span
				>
				<h4 class="font-headline text-xl">Diseño Arquitectónico</h4>
				<p class="text-on-surface-variant text-sm font-body">
					Conceptualización y desarrollo de proyectos residenciales de
					alta gama.
				</p>
			</div>
			<!-- Service 2 -->
			<div
				class="bg-surface p-12 space-y-8 group hover:bg-surface-container-highest transition-colors duration-500"
			>
				<span
					class="material-symbols-outlined text-4xl text-primary"
					data-icon="domain">domain</span
				>
				<h4 class="font-headline text-xl">Diseño Arquitectónico</h4>
				<p class="text-on-surface-variant text-sm font-body">
					Diseño de espacios públicos y planes maestros de integración
					urbana.
				</p>
			</div>
			<!-- Service 3 -->
			<div
				class="bg-surface p-12 space-y-8 group hover:bg-surface-container-highest transition-colors duration-500"
			>
				<span
					class="material-symbols-outlined text-4xl text-primary"
					data-icon="construction">construction</span
				>
				<h4 class="font-headline text-xl">Diseño Arquitectónico</h4>
				<p class="text-on-surface-variant text-sm font-body">
					Supervisión técnica rigurosa para asegurar la integridad de
					la visión.
				</p>
			</div>
			<!-- Service 4 -->
			<div
				class="bg-surface p-12 space-y-8 group hover:bg-surface-container-highest transition-colors duration-500"
			>
				<span
					class="material-symbols-outlined text-4xl text-primary"
					data-icon="view_in_ar">view_in_ar</span
				>
				<h4 class="font-headline text-xl">Diseño Arquitectónico</h4>
				<p class="text-on-surface-variant text-sm font-body">
					Modelado de información de construcción de alta fidelidad.
				</p>
			</div>
		</div>
	</section>
	<!-- Team Section -->
	<Team />

	<!-- Contact Section -->
	<section
		class="flex flex-col md:flex-row w-full min-h-[600px] bg-primary text-on-primary"
		id="contact"
	>
		<div
			class="w-full md:w-1/2 p-12 lg:p-24 flex flex-col justify-center space-y-12 bg-gradient-to-br from-primary to-primary-container"
		>
			<h2 class="font-headline text-5xl md:text-7xl">
				Hablemos de su próximo proyecto.
			</h2>
			<div
				class="space-y-4 font-label text-xs uppercase tracking-widest text-on-primary-fixed-variant"
			>
				<p>Arq. Héctor Manolo X. Rabay - Colegiado: 7,198</p>
				<p>3era. Calle 4-49 zona 4, Sumpango Sacatepéquez</p>
				<p>proyectoshmarq@hmail.com</p>
				<p>arqhectormanolo@gmail.com</p>
				<p>Contacto: 33999134 / 42046904</p>
			</div>
		</div>
		<div class="w-full md:w-1/2 p-12 lg:p-24 bg-primary flex items-center">
			<form class="w-full space-y-12">
				<div class="relative">
					<label
						class="font-label text-[10px] uppercase tracking-widest text-outline-variant block mb-2"
						>Nombre Completo</label
					>
					<input
						class="w-full bg-transparent border-t-0 border-x-0 border-b border-outline-variant focus:ring-0 focus:border-tertiary px-0 py-2 text-on-primary placeholder-on-primary/20"
						placeholder="NOMBRE COMPLETO"
						type="text"
					/>
				</div>
				<div class="relative">
					<label
						class="font-label text-[10px] uppercase tracking-widest text-outline-variant block mb-2"
						>Correo Electrónico</label
					>
					<input
						class="w-full bg-transparent border-t-0 border-x-0 border-b border-outline-variant focus:ring-0 focus:border-tertiary px-0 py-2 text-on-primary placeholder-on-primary/20"
						placeholder="EMAIL@EXAMPLE.COM"
						type="email"
					/>
				</div>
				<div class="relative">
					<label
						class="font-label text-[10px] uppercase tracking-widest text-outline-variant block mb-2"
						>Message</label
					>
					<textarea
						class="w-full bg-transparent border-t-0 border-x-0 border-b border-outline-variant focus:ring-0 focus:border-tertiary px-0 py-2 text-on-primary placeholder-on-primary/20"
						placeholder="DESCRIPCIÓN BREVE DEL PROYECTO"
						rows="3"></textarea>
				</div>
				<button
					class="w-full py-6 bg-tertiary text-on-primary font-label uppercase tracking-widest text-sm hover:bg-tertiary-fixed transition-colors duration-300"
					type="submit"
				>
					Enviar Consulta
				</button>
			</form>
		</div>
	</section>
</Layout>
